{
  "name": "reload",
  "displayName": "Reload",
  "description": "A simple extension to reload the current window with an optional confirmation dialog.",
  "version": "0.0.1",
  "author": {
    "name": "Deri Kurniawan",
    "email": "hi@derikn.com",
    "url": "https://www.derikn.com"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Reload",
      "type": "object",
      "properties": {
        "reload.confirmReload": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before reloading the window"
        }
      }
    },
    "commands": [
      {
        "command": "reload.reloadWindow",
        "title": "Reload Window"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}